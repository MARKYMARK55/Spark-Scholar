# =============================================================================
# Spark-Scholar Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env/.env.example env/.env
#
# The .env file is gitignored — it never gets committed.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED: Core infrastructure
# ---------------------------------------------------------------------------

# vLLM / SparkRun inference server
VLLM_URL=http://host.docker.internal:8000
VLLM_API_KEY=simple-api-key
VLLM_MODEL_NAME=local-model

# LiteLLM proxy
LITELLM_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
LITELLM_API_KEY=simple-api-key

# Open WebUI session signing
WEBUI_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# HuggingFace (for gated models and dataset uploads)
HF_TOKEN=hf_CHANGE_ME

# ---------------------------------------------------------------------------
# Local services (private llm-net network, not internet-facing)
# ---------------------------------------------------------------------------

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=simple-api-key

# BGE-M3 embedding service endpoints
DENSE_EMBED_URL=http://localhost:8025/v1/embeddings
SPARSE_EMBED_URL=http://localhost:8035/v1/embeddings
RERANKER_URL=http://localhost:8020/rerank
BGE_M3_API_KEY=simple-api-key

# Docling PDF conversion (runs in pipelines container)
DOCLING_URL=http://localhost:9099/docling/convert

# Redis cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=86400

# SearXNG search
SEARXNG_API_KEY=simple-api-key

# Chunk sizes for PDF ingestion
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---------------------------------------------------------------------------
# OPTIONAL: Langfuse tracing (leave as placeholders to disable)
# ---------------------------------------------------------------------------

LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_HOST=http://localhost:3000

# ---------------------------------------------------------------------------
# OPTIONAL: Academic research API keys (tools degrade gracefully without)
# ---------------------------------------------------------------------------

SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
NCBI_API_KEY=
CORE_API_KEY=
CROSSREF_MAILTO=

# ---------------------------------------------------------------------------
# OPTIONAL: Cloud LLM API keys (for litellm_cloud.yaml)
# Leave blank for fully local operation.
# ---------------------------------------------------------------------------

OPENAI_API_KEY=simple-api-key
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Email notifications (used by scripts/notify.sh)
# ---------------------------------------------------------------------------

NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
NOTIFY_APP_PASSWORD=
