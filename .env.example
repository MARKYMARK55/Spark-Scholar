# =============================================================================
#                     IMPORTANT: .env File Guide
# =============================================================================
#
# WHAT IS A .env FILE?
# --------------------
# A .env file stores environment variables in KEY=VALUE format.
# It keeps sensitive information (API keys, passwords, URLs) OUT of source code.
# NEVER commit .env to git — it is listed in .gitignore for this reason.
# Commit only this file (.env.example) which contains safe placeholder values.
#
# HOW TO CREATE YOUR .env
# -----------------------
# 1. Copy this file:
#        cp .env.example env/.env
# 2. Open env/.env and replace every placeholder with your real value
# 3. Never paste real keys into shared chats, logs, or public repos
#
# HOW DOCKER COMPOSE LOADS IT
# ----------------------------
# Every docker-compose service in docker/docker-compose.yml contains:
#        env_file: ../env/.env
# Docker Compose reads this file automatically — no extra steps needed.
# Variables are injected into each container's environment at startup.
#
# HOW PYTHON SCRIPTS LOAD IT
# --------------------------
# Scripts in ingest/ and pipeline/ use python-dotenv:
#        from dotenv import load_dotenv
#        load_dotenv("env/.env")        # or load_dotenv() if run from repo root
#        import os
#        key = os.getenv("QDRANT_API_KEY")
#
# HOW SHELL SCRIPTS LOAD IT
# --------------------------
#        source env/.env                   # interactive shell
#        export $(grep -v '^#' env/.env | xargs)   # non-interactive
#
# SECURITY BEST PRACTICES
# -----------------------
# - Use `openssl rand -base64 32` to generate strong random keys
# - For production: use a secrets manager (HashiCorp Vault, AWS Secrets Manager,
#   Doppler, 1Password) instead of a flat .env file
# - Rotate keys if a .env file is accidentally committed — don't just delete it;
#   the git history still contains it until you rewrite history with BFG
#
# THE simple-api-key PATTERN
# --------------------------
# Services running on the private llm-net Docker network use `simple-api-key`
# as their API key. This is intentional — these services are NOT exposed to the
# internet and the key prevents accidental open access from misconfigured containers.
# Do NOT use simple-api-key for any external-facing or cloud service.
# The LITELLM_MASTER_KEY is the exception — generate a strong random value for it.
#
# =============================================================================


# =============================================================================
# ── CORE LOCAL SERVICES (required — stack will not start without these) ──────
# =============================================================================

# Qdrant vector database
# Running on llm-net; use http://qdrant:6333 from inside Docker containers
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=simple-api-key

# BGE-M3 dense embedder (vLLM, port 8025)
BGE_M3_DENSE_URL=http://localhost:8025
# BGE-M3 sparse embedder (custom FastAPI, port 8035)
BGE_M3_SPARSE_URL=http://localhost:8035
# BGE-M3 cross-encoder reranker (vLLM, port 8020)
BGE_RERANKER_URL=http://localhost:8020
# Shared API key set via --api-key in all three vLLM/FastAPI services
BGE_M3_API_KEY=simple-api-key

# vLLM inference server (main LLM — Nemotron, Qwen3, etc.)
VLLM_URL=http://localhost:8000
VLLM_API_KEY=simple-api-key
VLLM_MODEL_NAME=nvidia/Llama-3.1-Nemotron-70B-Instruct-HF

# LiteLLM proxy (unified OpenAI-compatible gateway)
# LITELLM_API_KEY    — used by all clients for normal requests
# LITELLM_MASTER_KEY — used only for admin UI (generate a strong random value)
# LITELLM_BASE_URL   — how Docker containers on llm-net reach LiteLLM
LITELLM_URL=http://localhost:4000
LITELLM_API_KEY=simple-api-key
LITELLM_MASTER_KEY=sk-change-me-use-openssl-rand-base64-32
LITELLM_BASE_URL=http://litellm:4000

# Local vLLM API key as registered in litellm_config.yaml
# Must match --api-key on your vLLM serve command
LOCAL_VLLM_API_KEY=simple-api-key

# Nemotron-specific API key (same as LOCAL_VLLM_API_KEY unless using NVIDIA NIM)
NEMOTRON_API_KEY=simple-api-key

# Open WebUI
# OPENAI_API_BASE_URL — point at LiteLLM (port 4000) for direct access,
#                       or at the RAG proxy (port 8002) for Arxiv-augmented responses
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=simple-api-key
WEBUI_SECRET_KEY=simple-api-key

# Redis / Valkey cache
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Pipelines service
PIPELINES_API_KEY=simple-api-key

# SearXNG (private web search — no auth by default, set if you added one)
SEARXNG_URL=http://localhost:8888
SEARXNG_API_KEY=simple-api-key

# RAG Proxy service (FastAPI, api/)
RAG_PROXY_PORT=8002
RAG_PROXY_HOST=0.0.0.0

# Postgres (LiteLLM and Langfuse — must match docker-compose.yml values)
LITELLM_DATABASE_URL=postgresql://litellm:litellm_pass@litellm-db:5432/litellm
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse_pass@langfuse-db:5432/langfuse


# =============================================================================
# ── OBSERVABILITY (optional — tracing silently disabled if not set) ──────────
# =============================================================================

# Langfuse — get keys from http://localhost:3000 after starting the langfuse profile
# or from https://cloud.langfuse.com for the hosted version
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_HOST=http://localhost:3000

# LangChain tracing (optional alternative to Langfuse)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=arxiv-rag


# =============================================================================
# ── RETRIEVAL PARAMETERS ─────────────────────────────────────────────────────
# =============================================================================

# RAG_TOP_K         : final results returned to LLM after reranking
# RAG_RERANK_TOP_N  : candidates sent to cross-encoder (should be 3-5x TOP_K)
# CACHE_TTL_SECONDS : Valkey/Redis TTL for cached responses
#                     86400 = 24 hours (recommended for single-user DGX Spark)
#                     3600  = 1 hour (use for shared/multi-user deployments)
RAG_TOP_K=10
RAG_RERANK_TOP_N=50
CACHE_TTL_SECONDS=86400

# PDF chunking (used by ingest/05_ingest_pdfs.py only — NOT for Arxiv abstracts)
# CHUNK_SIZE    : target size in tokens (tiktoken cl100k_base)
# CHUNK_OVERLAP : overlap between consecutive chunks in tokens
CHUNK_SIZE=1000
CHUNK_OVERLAP=150


# =============================================================================
# ── HUGGING FACE ─────────────────────────────────────────────────────────────
# =============================================================================

# Required for downloading the Arxiv metadata dataset and gated models (Llama etc.)
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here


# =============================================================================
# ── ACADEMIC / RESEARCH APIs (optional — used by pipeline tools) ─────────────
# =============================================================================

# Semantic Scholar — paper metadata, citations, recommendations
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key

# OpenAlex — open academic graph, 250M+ works
# https://docs.openalex.org/how-to-use-the-api/api-key
OPENALEX_API_KEY=your-openalex-api-key

# Connected Papers — visual paper exploration
CONNECTED_PAPERS_API_KEY=your-connected-papers-api-key

# NCBI / PubMed — biomedical literature
# https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your-ncbi-api-key

# CORE — open access research
# https://core.ac.uk/services/api
CORE_API_KEY=your-core-api-key

# Ai2 / AllenAI (OLMo, Semantic Scholar, etc.)
AI2_API_KEY=your-ai2-api-key
ASTA_TOOL_KEY=your-asta-tool-key


# =============================================================================
# ── CLOUD LLM FALLBACKS (optional — only needed for cloud model routing) ─────
# =============================================================================
# These are used by LiteLLM when cloud model names are requested.
# The stack works fully locally without any of these keys.
# Leave as-is (placeholder values) if you want local-only operation.

# NVIDIA NIM cloud inference
NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# xAI / Grok
XAI_API_KEY=xai-your-xai-api-key

# Perplexity AI (sonar, sonar-pro, sonar-deep-research)
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Alibaba DashScope (Qwen cloud models)
DASHSCOPE_API_KEY=sk-your-dashscope-key

# Google Gemini / Vertex AI
GEMINI_API_KEY=AIyour-gemini-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# DeepInfra
DEEPINFRA_API_KEY=your-deepinfra-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=sk-or-your-openrouter-key
