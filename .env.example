# =============================================================================
#  spark-scholar  ·  env/.env  ·  Environment Configuration
# =============================================================================
#
# QUICK START (just 3 steps):
#   1.  cp .env.example env/.env
#   2.  Set VLLM_MODEL_NAME to match what SparkRun has loaded
#   3.  docker compose -f core_services/core_services.yml up -d
#
# That's it for local-only operation — all local service keys are pre-set.
# Fill in the cloud API keys (section 12) only if you want cloud model access.
# See env/README.md for a full reference table.
#
# RULES:
#   ✓  Commit .env.example  (safe placeholder values — already in git)
#   ✗  NEVER commit env/.env  (real secrets — already in .gitignore)
#
# KEY PATTERN:
#   All services on the private llm-net Docker network use  simple-api-key.
#   This is intentional — the network is not internet-facing and the key
#   prevents accidental cross-container open access.
#   The two keys you SHOULD change for production/shared use are:
#     LITELLM_MASTER_KEY  — admin access to the LiteLLM UI
#     WEBUI_SECRET_KEY    — signs Open WebUI session cookies
#   For a single-user DGX Spark on a private network, simple-api-key is fine.
#
#   Generate a strong random key:  openssl rand -base64 32
#
# =============================================================================


# =============================================================================
# ── 1. INFERENCE MODEL — SparkRun (required) ─────────────────────────────────
# =============================================================================
# SparkRun manages the vLLM inference process on your DGX Spark.
# github.com/scitrera/oss-spark-run
#
# VLLM_URL: how Docker containers reach the SparkRun process on the host.
#   Inside containers → host.docker.internal resolves to the Docker host.
#   host.docker.internal is added automatically by the LiteLLM service.
VLLM_URL=http://host.docker.internal:8000
VLLM_API_KEY=simple-api-key

# The model name you passed to SparkRun.
# Must match what vLLM reports at GET http://localhost:8000/v1/models
# Examples:
#   nvidia/Llama-3.1-Nemotron-70B-Instruct-HF
#   Qwen/Qwen3-30B-A3B
#   nvidia/Nemotron-H-56B-Instruct-HF
VLLM_MODEL_NAME=nvidia/Llama-3.1-Nemotron-70B-Instruct-HF

# Secondary model: Phi Mini (optional — only needed if you run a second SparkRun instance)
# sparkrun start microsoft/Phi-4-mini-instruct --port 8001
# Leave as default unless you change the port.
VLLM_PHI_URL=http://host.docker.internal:8001


# =============================================================================
# ── 2. EMBEDDING & RERANKING SERVICES ────────────────────────────────────────
# =============================================================================
# Three BGE-M3 services — all on llm-net, all use simple-api-key.
# From inside containers, use service hostnames (not localhost).
# From host Python scripts, use localhost.

# Dense embedder (vLLM, port 8025)
BGE_M3_DENSE_URL=http://localhost:8025
BGE_M3_DENSE_URL_DOCKER=http://bge-m3-dense-embedder:8025

# Sparse embedder (custom FastAPI, port 8035)
BGE_M3_SPARSE_URL=http://localhost:8035
BGE_M3_SPARSE_URL_DOCKER=http://bge-m3-sparse-embedder:8035

# Cross-encoder reranker (vLLM, port 8020)
BGE_RERANKER_URL=http://localhost:8020
BGE_RERANKER_URL_DOCKER=http://bge-m3-reranker:8020

# Shared API key for all three (must match --api-key in vLLM/uvicorn args)
BGE_M3_API_KEY=simple-api-key


# =============================================================================
# ── 3. QDRANT VECTOR DATABASE ────────────────────────────────────────────────
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=simple-api-key

# Inside containers, use the service hostname:
#   QDRANT_URL_DOCKER=http://qdrant:6333  (handled by compose env block)


# =============================================================================
# ── 4. LITELLM PROXY (local models) ──────────────────────────────────────────
# =============================================================================
# LITELLM_API_KEY    — used by ALL clients for normal requests (simple-api-key)
# LITELLM_MASTER_KEY — admin UI only  →  CHANGE THIS to a strong random value
#   openssl rand -base64 32
LITELLM_URL=http://localhost:4000
LITELLM_API_KEY=simple-api-key
LITELLM_MASTER_KEY=simple-api-key
LITELLM_BASE_URL=http://litellm:4000
LITELLM_DATABASE_URL=postgresql://litellm:litellm_pass@litellm-db:5432/litellm


# =============================================================================
# ── 5. OPEN WEBUI ────────────────────────────────────────────────────────────
# =============================================================================
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=simple-api-key
# WEBUI_SECRET_KEY — generate a strong random value (used to sign sessions)
WEBUI_SECRET_KEY=simple-api-key


# =============================================================================
# ── 6. RAG PROXY ─────────────────────────────────────────────────────────────
# =============================================================================
RAG_PROXY_HOST=0.0.0.0
RAG_PROXY_PORT=8002

# Retrieval tuning (see README — Retrieval Parameters section)
RAG_TOP_K=10                   # final results after reranking
RAG_RERANK_TOP_N=50            # candidates passed to cross-encoder

# PDF / HTML chunk settings (ingest/05, ingest/07)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150


# =============================================================================
# ── 7. REDIS / VALKEY CACHE ──────────────────────────────────────────────────
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTL in seconds
#   86400 = 24 hours  (recommended — single-user DGX Spark, stable dataset)
#   3600  = 1 hour    (use for multi-user or fast-changing datasets)
CACHE_TTL_SECONDS=86400


# =============================================================================
# ── 8. SEARXNG (private web search) ──────────────────────────────────────────
# =============================================================================
SEARXNG_URL=http://localhost:8888
SEARXNG_API_KEY=simple-api-key


# =============================================================================
# ── 9. LANGFUSE OBSERVABILITY (optional) ─────────────────────────────────────
# =============================================================================
# Self-hosted:
#   1.  docker compose -f core_services/langfuse.yml up -d
#   2.  Open http://localhost:3000
#   3.  Create account → project → API Keys
#   4.  Paste keys below and restart rag-proxy
#
# Cloud (hosted):
#   https://cloud.langfuse.com  →  Settings → API Keys
#
# Leave as placeholder to disable tracing (pipeline silently no-ops).
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_HOST=http://localhost:3000


# =============================================================================
# ── 10. HUGGING FACE ──────────────────────────────────────────────────────────
# =============================================================================
# Required for:
#   - Downloading the Arxiv metadata dataset (ingest/01_download_arxiv.py)
#   - Downloading gated models (Llama, Nemotron, etc.)
# Get your token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here


# =============================================================================
# ── 11. ACADEMIC / RESEARCH API KEYS (used by Open WebUI tools) ──────────────
# =============================================================================
# These power the Open WebUI workspace tools for literature search.
# Each tool in openWebUI/workspace_tools/ uses the corresponding key.
# All are optional — tools gracefully degrade without a key.

# Semantic Scholar — paper search, citations, recommendations, author graph
#   Free tier: 100 req/5min (no key).  Authenticated: 1 req/s.
#   Register: https://www.semanticscholar.org/product/api
#   Dashboard: https://api.semanticscholar.org/api-docs/
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex — 250M+ scholarly works, open access, no auth required for basic use
#   Key unlocks higher rate limits (10 req/s → 100 req/s)
#   Register: https://openalex.org/  →  "Get API key" (free)
OPENALEX_API_KEY=

# PubMed / NCBI — biomedical literature (PubMed, PMC, Gene, etc.)
#   Register: https://www.ncbi.nlm.nih.gov/account/
#   API key dashboard: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# CORE — open access research aggregator (200M+ papers)
#   Register: https://core.ac.uk/services/api
CORE_API_KEY=

# Crossref — DOI metadata, citation counts (no key for basic use)
#   Polite pool (faster): https://www.crossref.org/documentation/retrieve-metadata/rest-api/
CROSSREF_MAILTO=your-email@example.com

# Europe PMC — life sciences literature
#   Public API, no key required. Set for higher rate limits.
#   https://europepmc.org/RestfulWebService
EUROPE_PMC_EMAIL=your-email@example.com

# Dimensions — research intelligence (requires institutional access or free account)
#   https://www.dimensions.ai/
DIMENSIONS_API_KEY=

# Lens.org — patents, grants, publications (rate-limited free tier)
#   https://www.lens.org/lens/user/subscriptions
LENS_API_KEY=

# Connected Papers — paper similarity graph, prior/derivative works
#   https://www.connectedpapers.com/api
CONNECTED_PAPERS_API_KEY=

# Ai2 / Allen Institute — Semantic Scholar parent org, Asta MCP full-text search
#   SEMANTIC_SCHOLAR_API_KEY is the standard key for S2 Graph API
#   AI2_API_KEY is used by the Ai2_tools.json extended toolset
#   ASTA_TOOL_KEY is used by the Asta MCP semantic search endpoint
#   Register: https://www.semanticscholar.org/product/api
AI2_API_KEY=
ASTA_TOOL_KEY=


# =============================================================================
# ── 12. CLOUD LLM API KEYS (for litellm_cloud.yaml) ─────────────────────────
# =============================================================================
# These are used when you add cloud models to LiteLLM.
# See: core_services/litellm_cloud.yaml
# To activate: add models via LiteLLM admin UI (http://localhost:4000/ui)
#              or mount litellm_cloud.yaml in core_services.yml.
# Leave blank for fully local operation — no cloud keys required.

# OpenAI
#   https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# NVIDIA NIM cloud (access Nemotron and other NVIDIA models via API)
#   https://build.nvidia.com  →  "Get API Key" (free tier available)
NVIDIA_API_KEY=

# xAI Grok
#   https://console.x.ai/
XAI_API_KEY=

# DeepSeek
#   https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Perplexity (sonar, sonar-pro, sonar-deep-research — web-search augmented)
#   https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# OpenRouter — single key for 200+ models (GPT, Claude, Gemini, open-source)
#   https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Alibaba DashScope (Qwen cloud models)
#   https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Groq (fast inference for open-source models)
#   https://console.groq.com/keys
GROQ_API_KEY=

# Together AI (fine-tuning + inference)
#   https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=


# =============================================================================
# ── 13. LANGCHAIN TRACING (alternative to Langfuse) ──────────────────────────
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=spark-scholar
